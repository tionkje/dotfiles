#!/bin/bash
# Toggle quick-settings popup centered under the cursor, just below waybar
set -euo pipefail
trap 'notify-send -u critical "Error: $(basename "$0")" "Line $LINENO failed (exit $?)"' ERR

if eww active-windows | grep -q 'quick-settings'; then
  eww close quick-settings quick-settings-backdrop
  exit 0
fi

CURSOR=$(hyprctl cursorpos)
CX=${CURSOR%%,*}

MON_JSON=$(hyprctl monitors -j | jq '.[] | select(.focused)')
MON_ID=$(echo "$MON_JSON" | jq '.id')
MON_X=$(echo "$MON_JSON" | jq '.x')

REL_X=$(( CX - MON_X - 60 ))

eww open quick-settings-backdrop --screen "$MON_ID"
eww open quick-settings --screen "$MON_ID" --pos "${REL_X}x24" --anchor "top left"
