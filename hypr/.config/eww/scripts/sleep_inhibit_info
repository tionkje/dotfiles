#!/usr/bin/env bash
set -euo pipefail
trap 'notify-send -u critical "Error: $(basename "$0")" "Line $LINENO failed (exit $?)"' ERR

STATE_FILE="/tmp/eww-sleep-inhibit"
PREV_AC=""

while true; do
    inhibited="false"
    [ -f "$STATE_FILE" ] && inhibited="true" || true  # expected: file may not exist

    # Auto-disable inhibit when switching from AC to battery
    AC=$(cat /sys/class/power_supply/AC/online 2>/dev/null) || AC=""
    if [ "$PREV_AC" = "1" ] && [ "$AC" = "0" ] && [ "$inhibited" = "true" ]; then
        rm -f "$STATE_FILE"
        if ! pgrep -x hypridle >/dev/null; then
            hypridle &
            disown
        fi
        inhibited="false"
        notify-send "Sleep inhibit off" "Switched to battery — hypridle re-enabled"
    fi
    PREV_AC="$AC"

    echo "{\"inhibited\": $inhibited}"
    sleep 2
done
